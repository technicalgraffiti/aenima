{
  "functions": {
    "api/create-checkout.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/stripe-webhook.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/check-domain.js": {
      "memory": 256,
      "maxDuration": 25
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "check.technicalgraffiti.co.uk"
        }
      ],
      "destination": "/public/tg-check.html"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}