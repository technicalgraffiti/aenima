{
  "functions": {
    "api/create-checkout.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/stripe-webhook.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/check-domain.js": {
      "memory": 256,
      "maxDuration": 25
    },
    "api/customer-portal.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/monthly-cron.js": {
      "memory": 512,
      "maxDuration": 60
    },
    "api/generate-report.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/send-report-email.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/tg-check",
      "dest": "/public/tg-check.html"
    },
    {
      "src": "/tg-check.html",
      "dest": "/public/tg-check.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/monthly-cron",
      "schedule": "0 8 1 * *"
    }
  ]
}